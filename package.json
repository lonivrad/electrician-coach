{
  "name": "electrician-coach",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Adaptive diagnostic tutor for licensing exams. Exam-agnostic engine + pluggable content packs. First pack: WA 01 General Journeyman.",
  "author": "lonivrad",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lonivrad/electrician-coach.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "validate:pack": "tsx scripts/validate-pack.ts"
  },
  "dependencies": {
    "js-yaml": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "axe-core": "^4.12.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.23.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.6",
    "vitest-axe": "^0.1.0"
  }
}
