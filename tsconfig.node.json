{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "baseUrl": ".",
    "paths": {
      "@engine/*": ["engine/*"],
      "@packs/*": ["content-packs/*"]
    }
  },
  "include": ["vite.config.ts", "vitest.config.ts", "eslint.config.js", "scripts", "tests", "src/vite-env.d.ts"]
}
